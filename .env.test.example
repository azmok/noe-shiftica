# Copy this file to .env.test (never commit .env.test)
# Used by: pnpm test:integration, pnpm test:setup, and pnpm dev:test

# Dev server base URL (default: http://localhost:3000)
TEST_BASE_URL=http://localhost:3000

# Password for the test admin account (indexlove0815@icloud.com)
# Choose a strong password and run `pnpm test:setup` once to create the account
TEST_ADMIN_PASSWORD=YourSecureTestPassword123!

# Neon test branch connection string (test/integration branch — NOT production)
# Create with: neonctl branches create --name test/integration --parent production
# Get the connection string with: neonctl connection-string --branch test/integration
TEST_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_ENDPOINT.neon.tech/neondb?sslmode=require
